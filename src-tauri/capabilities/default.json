{
  "identifier": "panel-capabilities",
  "description": "Capabilities for the floating panel window",
  "windows": ["panel"],
  "permissions": [
    "core:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "store:allow-get",
    "store:allow-set"
  ]
}
