{
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-keys"
  ]
}
