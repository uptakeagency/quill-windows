{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quill",
  "version": "0.1.0",
  "identifier": "com.c3nx.quill-windows",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "",
        "width": 420,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "focus": false,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Quill Settings",
        "width": 500,
        "height": 450,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
